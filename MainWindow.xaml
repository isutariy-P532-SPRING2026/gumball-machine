<Window x:Class="GumballMachine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gumball Machine" Height="500" Width="480"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Gumball Machine" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <!-- Status Panel -->
        <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="State: " FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StateLabel" FontSize="14" Foreground="#CBA6F7" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Gumballs: " FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CountLabel" FontSize="14" Foreground="#A6E3A1" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,12">
            <Button x:Name="InsertBtn" Content="Insert Quarter" Margin="4"
                    Padding="8,10" Click="InsertQuarter_Click"/>
            <Button x:Name="EjectBtn" Content="Eject Quarter" Margin="4"
                    Padding="8,10" Click="EjectQuarter_Click"/>
            <Button x:Name="CrankBtn" Content="Turn Crank" Margin="4"
                    Padding="8,10" Click="TurnCrank_Click"/>
        </UniformGrid>

        <!-- Output Log -->
        <Border Grid.Row="3" Background="#1E1E2E" CornerRadius="8" Padding="8">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogBox" FontSize="13" Foreground="#CDD6F4"
                           FontFamily="Consolas" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Refill -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="Refill amount:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="RefillBox" Width="50" Text="5" Padding="4,2"/>
            <Button Content="Refill" Margin="8,0,0,0" Padding="12,4" Click="Refill_Click"/>
        </StackPanel>
    </Grid>
</Window>
